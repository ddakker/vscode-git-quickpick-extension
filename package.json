{
  "name": "git-reflow",
  "displayName": "Git QuickPick",
  "description": "%extension.description%",
  "version": "0.10.1",
  "publisher": "ddakker",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "gitQuickPickExplorer",
          "title": "Git QuickPick",
          "icon": "git-quickpick-icon.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "gitQuickPickView",
          "name": "%view.workspace%",
          "contextualTitle": "Git QuickPick",
          "when": "false"
        }
      ],
      "gitQuickPickExplorer": [
        {
          "id": "gitQuickPickHistory",
          "name": "%view.history%",
          "type": "webview",
          "contextualTitle": "Git QuickPick",
          "initialSize": 3
        }
      ]
    },
    "configuration": {
      "title": "Git QuickPick",
      "properties": {
        "gitReflow.language": {
          "type": "string",
          "default": "auto",
          "order": 1,
          "enum": [
            "auto",
            "ko",
            "en"
          ],
          "enumDescriptions": [
            "%config.language.auto%",
            "%config.language.ko%",
            "%config.language.en%"
          ],
          "description": "%config.language%"
        },
        "gitReflow.messageInputPosition": {
          "type": "string",
          "default": "bottom",
          "order": 3,
          "enum": [
            "top",
            "bottom"
          ],
          "description": "%config.messageInputPosition%"
        },
        "gitReflow.showInputWhenChecked": {
          "type": "boolean",
          "default": true,
          "order": 4,
          "description": "%config.showInputWhenChecked%"
        },
        "gitReflow.commitFieldOrder": {
          "type": "string",
          "default": "message,date,author,hash",
          "order": 6,
          "enum": [
            "message,date,author,hash",
            "message,author,date,hash",
            "date,message,author,hash",
            "author,date,hash,message",
            "hash,message,author,date"
          ],
          "enumDescriptions": [
            "%config.commitFieldOrder.opt1%",
            "%config.commitFieldOrder.opt2%",
            "%config.commitFieldOrder.opt3%",
            "%config.commitFieldOrder.opt4%",
            "%config.commitFieldOrder.opt5%"
          ],
          "description": "%config.commitFieldOrder%"
        },
        "gitReflow.authorWidth": {
          "type": "number",
          "default": 90,
          "minimum": 40,
          "maximum": 300,
          "order": 7,
          "description": "%config.authorWidth%"
        },
        "gitReflow.backupBeforeRebase": {
          "type": "boolean",
          "default": true,
          "order": 9,
          "description": "%config.backupBeforeRebase%"
        },
        "gitReflow.backupMaxKeep": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "order": 10,
          "description": "%config.backupMaxKeep%"
        },
        "gitReflow.backupMaxAgeDays": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "order": 11,
          "description": "%config.backupMaxAgeDays%"
        }
      }
    },
    "commands": [
      {
        "command": "gitReflow.rebasemergeLocal",
        "title": "%command.rebasemergeLocal%",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitReflow.rebasemergeRemote",
        "title": "%command.rebasemergeRemote%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitReflow.pullBranch",
        "title": "%command.pullBranch%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "gitReflow.push",
        "title": "%command.push%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitReflow.commit",
        "title": "%command.commit%",
        "icon": "$(check)"
      },
      {
        "command": "gitReflow.reset",
        "title": "%command.reset%",
        "icon": "$(discard)"
      },
      {
        "command": "gitReflow.cherryPick",
        "title": "%command.cherryPick%",
        "icon": "$(record)"
      },
      {
        "command": "gitReflow.history",
        "title": "%command.history%",
        "icon": "$(history)"
      },
      {
        "command": "gitReflow.refreshView",
        "title": "%command.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "gitReflow.execPush",
        "title": "%command.execPush%",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "gitReflow.execForcePush",
        "title": "%command.execForcePush%",
        "icon": "$(warning)"
      },
      {
        "command": "gitReflow.execForcePull",
        "title": "%command.execForcePull%",
        "icon": "$(warning)"
      },
      {
        "command": "gitReflow.execPull",
        "title": "%command.execPull%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "gitReflow.execRebase",
        "title": "%command.execRebase%",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitReflow.execMerge",
        "title": "%command.execMerge%",
        "icon": "$(source-control)"
      },
      {
        "command": "gitReflow.execCherryPick",
        "title": "%command.execCherryPick%",
        "icon": "$(record)"
      },
      {
        "command": "gitReflow.execSoftReset",
        "title": "%command.execSoftReset%",
        "icon": "$(history)"
      },
      {
        "command": "gitReflow.execHardReset",
        "title": "%command.execHardReset%",
        "icon": "$(warning)"
      },
      {
        "command": "gitReflow.copyHash",
        "title": "%command.copyHash%",
        "icon": "$(clippy)"
      },
      {
        "command": "gitReflow.copyMessage",
        "title": "%command.copyMessage%",
        "icon": "$(clippy)"
      },
      {
        "command": "gitReflow.viewDiff",
        "title": "%command.viewDiff%",
        "icon": "$(diff)"
      },
      {
        "command": "gitReflow.resetToHere",
        "title": "%command.resetToHere%",
        "icon": "$(discard)"
      },
      {
        "command": "gitReflow.execSwitch",
        "title": "%command.execSwitch%",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "gitReflow.execCommit",
        "title": "%command.execCommit%",
        "icon": "$(play)"
      },
      {
        "command": "gitReflow.toggleFileView",
        "title": "%command.toggleFileView%",
        "icon": "$(list-tree)"
      },
      {
        "command": "gitReflow.stageFile",
        "title": "%command.stageFile%",
        "icon": "$(add)"
      },
      {
        "command": "gitReflow.rollbackFile",
        "title": "%command.rollbackFile%",
        "icon": "$(reply)"
      },
      {
        "command": "gitReflow.deleteFile",
        "title": "%command.deleteFile%",
        "icon": "$(trash)"
      },
      {
        "command": "gitReflow.createBranch",
        "title": "%command.createBranch%",
        "icon": "$(add)"
      },
      {
        "command": "gitReflow.execBranchPull",
        "title": "%command.execBranchPull%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitReflow.execForceBranchPull",
        "title": "%command.execForceBranchPull%",
        "icon": "$(warning)"
      },
      {
        "command": "gitReflow.execDeleteBranch",
        "title": "%command.execDeleteBranch%",
        "icon": "$(trash)"
      },
      {
        "command": "gitReflow.cleanupBackups",
        "title": "%command.cleanupBackups%",
        "icon": "$(trash)"
      },
      {
        "command": "gitReflow.openSettings",
        "title": "%command.openSettings%",
        "icon": "$(gear)"
      },
      {
        "command": "gitReflow.execDeleteRemoteBranch",
        "title": "%command.execDeleteRemoteBranch%",
        "icon": "$(trash)"
      },
      {
        "command": "gitReflow.execInteractiveRebase",
        "title": "%command.execInteractiveRebase%",
        "icon": "$(edit)"
      },
      {
        "command": "gitReflow.execAmendMessage",
        "title": "%command.execAmendMessage%",
        "icon": "$(edit)"
      },
      {
        "command": "gitReflow.jumpToSource",
        "title": "%command.jumpToSource%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitReflow.openConflictMergeEditor",
        "title": "%command.openConflictMergeEditor%",
        "icon": "$(git-merge)"
      },
      {
        "command": "gitReflow.openConflictInEditor",
        "title": "%command.openConflictInEditor%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitReflow.acceptMerge",
        "title": "%command.acceptMerge%",
        "icon": "$(check)"
      },
      {
        "command": "gitReflow.openCommitFileVsLocal",
        "title": "%command.openCommitFileVsLocal%",
        "icon": "$(compare-changes)"
      },
      {
        "command": "gitReflow.copyPath",
        "title": "%command.copyPath%"
      },
      {
        "command": "gitReflow.copyRelativePath",
        "title": "%command.copyRelativePath%"
      },
      {
        "command": "gitReflow.addToGitignore",
        "title": "%command.addToGitignore%",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitReflow.addForce",
        "title": "%command.addForce%",
        "icon": "$(add)"
      },
      {
        "command": "gitReflow.createStash",
        "title": "%command.createStash%",
        "icon": "$(archive)"
      },
      {
        "command": "gitReflow.stash",
        "title": "%command.stash%",
        "icon": "$(archive)"
      },
      {
        "command": "gitReflow.stashPop",
        "title": "%command.stashPop%",
        "icon": "$(reply)"
      },
      {
        "command": "gitReflow.stashApply",
        "title": "%command.stashApply%",
        "icon": "$(check)"
      },
      {
        "command": "gitReflow.stashDrop",
        "title": "%command.stashDrop%",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitReflow.execPush",
          "when": "view == gitQuickPickHistory",
          "group": "navigation@4"
        },
        {
          "command": "gitReflow.execPull",
          "when": "view == gitQuickPickHistory",
          "group": "navigation@5"
        },
        {
          "command": "gitReflow.createStash",
          "when": "view == gitQuickPickHistory && gitReflow.hasChanges",
          "group": "navigation@6"
        },
        {
          "command": "gitReflow.refreshView",
          "when": "view == gitQuickPickHistory",
          "group": "navigation@7"
        },
        {
          "command": "gitReflow.execForcePush",
          "when": "view == gitQuickPickHistory",
          "group": "1_push@1"
        },
        {
          "command": "gitReflow.execForcePull",
          "when": "view == gitQuickPickHistory",
          "group": "1_push@2"
        },
        {
          "command": "gitReflow.cleanupBackups",
          "when": "view == gitQuickPickHistory",
          "group": "2_backup@1"
        },
        {
          "command": "gitReflow.openSettings",
          "when": "view == gitQuickPickHistory",
          "group": "2_backup@2"
        }
      ],
      "view/item/context": [
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.stageFile",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "inline@2"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "inline@3"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "0_inline@1"
        },
        {
          "command": "gitReflow.stageFile",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "0_inline@2"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "0_inline@3"
        },
        {
          "command": "gitReflow.addToGitignore",
          "when": "view == gitQuickPickView && viewItem == fileUntracked",
          "group": "8_gitignore@1"
        },
        {
          "command": "gitReflow.openConflictMergeEditor",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.openConflictInEditor",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "inline@2"
        },
        {
          "command": "gitReflow.acceptMerge",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "inline@3"
        },
        {
          "command": "gitReflow.openConflictMergeEditor",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "0_inline@1"
        },
        {
          "command": "gitReflow.openConflictInEditor",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "0_inline@2"
        },
        {
          "command": "gitReflow.acceptMerge",
          "when": "view == gitQuickPickView && viewItem == fileConflict",
          "group": "0_inline@3"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.rollbackFile",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "inline@2"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "inline@3"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "0_inline@1"
        },
        {
          "command": "gitReflow.rollbackFile",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "0_inline@2"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "0_inline@3"
        },
        {
          "command": "gitReflow.addToGitignore",
          "when": "view == gitQuickPickView && viewItem == fileModified",
          "group": "8_gitignore@1"
        },
        {
          "command": "gitReflow.rollbackFile",
          "when": "view == gitQuickPickView && viewItem == fileDeleted",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.rollbackFile",
          "when": "view == gitQuickPickView && viewItem == fileDeleted",
          "group": "0_inline@1"
        },
        {
          "command": "gitReflow.addToGitignore",
          "when": "view == gitQuickPickView && viewItem == fileDeleted",
          "group": "8_gitignore@1"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileOther",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileOther",
          "group": "inline@2"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == fileOther",
          "group": "0_inline@1"
        },
        {
          "command": "gitReflow.deleteFile",
          "when": "view == gitQuickPickView && viewItem == fileOther",
          "group": "0_inline@2"
        },
        {
          "command": "gitReflow.addToGitignore",
          "when": "view == gitQuickPickView && viewItem == fileOther",
          "group": "8_gitignore@1"
        },
        {
          "command": "gitReflow.copyPath",
          "when": "view == gitQuickPickView && viewItem =~ /^file(Untracked|Modified|Deleted|Other|Conflict)$/",
          "group": "9_copy@1"
        },
        {
          "command": "gitReflow.copyRelativePath",
          "when": "view == gitQuickPickView && viewItem =~ /^file(Untracked|Modified|Deleted|Other|Conflict)$/",
          "group": "9_copy@2"
        },
        {
          "command": "gitReflow.createStash",
          "when": "view == gitQuickPickView && viewItem == stashSection",
          "group": "1_actions@1"
        },
        {
          "command": "gitReflow.stashPop",
          "when": "view == gitQuickPickView && viewItem == stashEntry",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.stashPop",
          "when": "view == gitQuickPickView && viewItem == stashEntry",
          "group": "1_actions@1"
        },
        {
          "command": "gitReflow.stashApply",
          "when": "view == gitQuickPickView && viewItem == stashEntry",
          "group": "1_actions@2"
        },
        {
          "command": "gitReflow.stashDrop",
          "when": "view == gitQuickPickView && viewItem == stashEntry",
          "group": "9_danger@1"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == stashFile",
          "group": "inline@1"
        },
        {
          "command": "gitReflow.jumpToSource",
          "when": "view == gitQuickPickView && viewItem == stashFile",
          "group": "0_inline@1"
        }
      ],
      "explorer/context": [
        {
          "command": "gitReflow.addForce",
          "when": "resourceScheme == file",
          "group": "7_modification@100"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ddakker/vscode-git-quickpick-extension"
  },
  "license": "Apache-2.0",
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').writeFileSync('build-info.json', JSON.stringify({ buildTime: new Date().toISOString() }))\"",
    "test": "node tests/run.js"
  }
}
